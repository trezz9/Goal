function completeLesson() {
if(!currentLessonCourse) return;
const course = allCourses.find(c => c.id === currentLessonCourse);
const enrolled = enrolledCourses[currentLessonCourse];
if(!enrolled.completedLessons.includes(currentLessonIndex)) enrolled.completedLessons.push(currentLessonIndex);
enrolled.progress = Math.min(100, Math.round((enrolled.completedLessons.length / course.modules.length) * 100));
showToast(‘✅ Lesson completed! Progress updated.’, ‘success’);
const nextIdx = currentLessonIndex + 1;
if(nextIdx < course.modules.length) { openLesson(currentLessonCourse, nextIdx); }
else { showToast(‘🏆 Course completed! Certificate earned!’, ‘success’); navigate(‘progress’); }
}

// ===== QUIZ =====
function renderQuiz() {
const enrolled = Object.keys(enrolledCourses);
const available = enrolled.filter(id => adminQuizBank[id] && adminQuizBank[id].length > 0);
if(available.length === 0) {
document.getElementById(‘quizContainer’).innerHTML = `<div class="empty-state"><div class="ei">📝</div><p>Enroll in a course first to take quizzes.</p><br><button class="btn btn-primary" onclick="navigate('courses')">Browse Courses</button></div>`;
return;
}
if(!currentQuiz.courseId || !enrolled.includes(currentQuiz.courseId)) currentQuiz.courseId = available[0];
startQuiz(currentQuiz.courseId);
}

window.startQuiz = function(courseId) {
currentQuiz = { courseId, qIndex: 0, answers: [], score: 0 };
navigate(‘quiz’);
renderQuizQuestion();
};

function renderQuizQuestion() {
const questions = adminQuizBank[currentQuiz.courseId] || [];
const course = allCourses.find(c => c.id === currentQuiz.courseId);
const { qIndex } = currentQuiz;

if(qIndex >= questions.length) { renderQuizResult(); return; }
const q = questions[qIndex];
const letters = [‘A’,‘B’,‘C’,‘D’];

document.getElementById(‘quizContainer’).innerHTML = `<div style="display:flex;align-items:center;gap:0.8rem;margin-bottom:1.2rem;"> <div style="width:36px;height:36px;border-radius:8px;background:${course?.bg||'#eef2ff'};display:flex;align-items:center;justify-content:center;font-size:1.1rem;">${course?.icon||'📝'}</div> <div><div style="font-weight:800;font-size:0.88rem;">${course?.title?.substring(0,40)||'Quiz'}...</div> <div class="quiz-progress-label"><span style="font-size:0.7rem;color:var(--text3);">Question ${qIndex+1} of ${questions.length}</span></div> </div> </div> <div class="prog-bar" style="height:6px;"><div class="prog-fill blue" style="width:${((qIndex)/questions.length)*100}%"></div></div> <div class="q-text">${qIndex+1}. ${q.q}</div> <div class="q-options"> ${q.opts.map((opt,i) =>`
<div class="q-option" onclick="selectAnswer(${i})" id="opt${i}">
<div class="q-opt-letter">${letters[i]}</div>
${opt}
</div>`).join('')} </div> <div class="quiz-nav"> <button class="btn btn-primary" id="nextBtn" onclick="submitAnswer()" style="display:none;">Next →</button> <button class="btn btn-outline" onclick="navigate('courses')" style="font-size:0.82rem;">Exit Quiz</button> <span style="margin-left:auto;font-size:0.78rem;color:var(--text3);">${qIndex+1}/${questions.length}</span> </div> `;
}

window.selectAnswer = function(idx) {
document.querySelectorAll(’.q-option’).forEach(o => o.classList.remove(‘selected’));
document.getElementById(‘opt’+idx)?.classList.add(‘selected’);
currentQuiz.selectedOption = idx;
document.getElementById(‘nextBtn’).style.display = ‘block’;
};

window.submitAnswer = function() {
const questions = adminQuizBank[currentQuiz.courseId];
const q = questions[currentQuiz.qIndex];
const sel = currentQuiz.selectedOption;
if(sel === undefined) return;
document.querySelectorAll(’.q-option’).forEach((o,i) => {
if(i === q.correct) o.classList.add(‘correct’);
else if(i === sel && i !== q.correct) o.classList.add(‘wrong’);
o.style.pointerEvents = ‘none’;
});
if(sel === q.correct) currentQuiz.score++;
currentQuiz.answers.push(sel);
currentQuiz.selectedOption = undefined;
document.getElementById(‘nextBtn’).textContent = currentQuiz.qIndex + 1 >= questions.length ? ‘See Results 🏁’ : ‘Next →’;
document.getElementById(‘nextBtn’).onclick = () => { currentQuiz.qIndex++; renderQuizQuestion(); };
};

function renderQuizResult() {
const questions = adminQuizBank[currentQuiz.courseId] || [];
const pct = Math.round((currentQuiz.score / questions.length) * 100);
const emoji = pct >= 80 ? ‘🏆’ : pct >= 60 ? ‘👍’ : ‘📖’;
const msg = pct >= 80 ? ‘Excellent work!’ : pct >= 60 ? ‘Good effort!’ : ‘Keep studying!’;
document.getElementById(‘quizContainer’).innerHTML = ` <div class="quiz-result"> <div style="font-size:3rem;margin-bottom:0.8rem;">${emoji}</div> <div class="quiz-score">${pct}%</div> <div class="quiz-score-sub">${currentQuiz.score} / ${questions.length} correct · ${msg}</div> <div style="display:flex;gap:0.8rem;justify-content:center;flex-wrap:wrap;"> <button class="btn btn-primary" onclick="startQuiz('${currentQuiz.courseId}')">🔄 Retake Quiz</button> <button class="btn btn-outline" onclick="navigate('courses')">Back to Courses</button> </div> </div>`;
if(pct === 100) showToast(‘Perfect score! 🌟 Achievement unlocked!’, ‘success’);
}

