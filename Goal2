function navigate(page) {
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const navEl = document.getElementById('nav-'+page);
  if(navEl) navEl.classList.add('active');
  const pageEl = document.getElementById('page-'+page);
  if(pageEl) pageEl.classList.add('active');

  const titles = {
    'dashboard':'Dashboard','courses':'All Courses','quiz':'Take a Quiz',
    'progress':'My Progress','profile':'My Profile','lesson':'Lesson',
    'admin-dashboard':'Admin Dashboard','admin-students':'Students',
    'admin-courses':'Courses','admin-quizzes':'Quizzes','admin-progress':'Progress Tracking'
  };
  document.getElementById('topbarTitle').textContent = titles[page] || page;

  if(page === 'dashboard') renderDashboard();
  else if(page === 'courses') renderCourses();
  else if(page === 'quiz') renderQuiz();
  else if(page === 'progress') renderProgress();
  else if(page === 'profile') renderProfilePage();
  else if(page === 'admin-dashboard') renderAdminDashboard();
  else if(page === 'admin-students') renderAdminStudents();
  else if(page === 'admin-courses') renderAdminCourses();
  else if(page === 'admin-quizzes') renderAdminQuizzes();
  else if(page === 'admin-progress') renderAdminProgress();
}

